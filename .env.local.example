# ──────────────────────────────────────────────
# Triple M Public School — Environment Variables
# Copy this file to .env.local and fill in values
# ──────────────────────────────────────────────

# ─── MongoDB Atlas ────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/triplem?retryWrites=true&w=majority

# ─── NextAuth.js ──────────────────────────────
AUTH_SECRET=generate-a-random-32-char-secret-here
AUTH_URL=http://localhost:3000
# Admin credentials (initial setup — change after first login)
ADMIN_EMAIL=admin@triplemschool.in
ADMIN_PASSWORD=change-this-strong-password

# ─── Cloudinary ───────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Nodemailer SMTP ─────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=triplem_school@yahoo.in
SMTP_PASSWORD=your-app-password
CONTACT_EMAIL_TO=triplem_school@yahoo.in

# ─── Upstash Redis (Rate Limiting) ───────────
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ─── Public (safe to expose) ─────────────────
NEXT_PUBLIC_SCHOOL_NAME=Triple M Public School
NEXT_PUBLIC_SCHOOL_PHONE=9888299600
NEXT_PUBLIC_SCHOOL_PHONE_ALT=01882-245100
NEXT_PUBLIC_SCHOOL_EMAIL=triplem_school@yahoo.in
NEXT_PUBLIC_SCHOOL_ADDRESS=Fatehgarh Road, Opp. New Saini Hospital & Narad Hospital, Near Session Chowk, Bansi Nagar, Hoshiarpur, Punjab 146001
NEXT_PUBLIC_GOOGLE_MAPS_EMBED=https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3405.123!2d75.911!3d31.532!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMzHCsDMxJzU1LjIiTiA3NcKwNTQnMzkuNiJF!5e0!3m2!1sen!2sin!4v1
